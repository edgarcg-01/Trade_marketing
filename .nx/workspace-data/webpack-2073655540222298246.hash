            "example": {
              "options": {
                "args": [
                  "--client-progress",
                  "--history-api-fallback "
                ]
              }
            }
          }
        }
      },
      "serve-static": {
        "dependsOn": [
          "webpack:build"
        ],
        "executor": "@nx/web:file-server",
        "options": {
          "buildTarget": "webpack:build",
          "spa": true
        }
      }
