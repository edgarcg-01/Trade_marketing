{
  "graph": {
    "nodes": {
      "shared-models": {
        "name": "shared-models",
        "type": "lib",
        "data": {
          "root": "libs/shared-models",
          "name": "shared-models",
          "$schema": "../../node_modules/nx/schemas/project-schema.json",
          "projectType": "library",
          "sourceRoot": "libs/shared-models/src",
          "targets": {
            "build": {
              "executor": "@nx/js:tsc",
              "outputs": [
                "{options.outputPath}"
              ],
              "options": {
                "outputPath": "dist/libs/shared-models",
                "main": "libs/shared-models/src/index.ts",
                "tsConfig": "libs/shared-models/tsconfig.lib.json",
                "assets": []
              },
              "configurations": {},
              "parallelism": true,
              "dependsOn": [
                "^build"
              ],
              "inputs": [
                "production",
                "^production"
              ]
            }
          },
          "implicitDependencies": [],
          "tags": []
        }
      },
      "view": {
        "name": "view",
        "type": "app",
        "data": {
          "root": "apps/view",
          "name": "view",
          "$schema": "../../node_modules/nx/schemas/project-schema.json",
          "projectType": "application",
          "sourceRoot": "apps/view/src",
          "prefix": "app",
          "targets": {
            "build": {
              "executor": "@nx/angular:browser-esbuild",
              "outputs": [
                "{options.outputPath}"
              ],
              "options": {
                "outputPath": "dist/apps/view",
                "index": "apps/view/src/index.html",
                "main": "apps/view/src/main.ts",
                "polyfills": [
                  "apps/view/src/polyfills.ts"
                ],
                "tsConfig": "apps/view/tsconfig.app.json",
                "assets": [
                  "apps/view/src/favicon.ico",
                  "apps/view/src/assets"
                ],
                "styles": [
                  "apps/view/src/styles.css"
                ],
                "scripts": []
              },
              "configurations": {
                "production": {
                  "aot": true,
                  "buildOptimizer": true,
                  "optimization": true,
                  "budgets": [
                    {
                      "type": "initial",
                      "maximumWarning": "2mb",
                      "maximumError": "5mb"
                    },
                    {
                      "type": "anyComponentStyle",
                      "maximumWarning": "4kb",
                      "maximumError": "10kb"
                    }
                  ],
                  "outputHashing": "all"
                },
                "development": {
                  "optimization": false,
                  "extractLicenses": false,
                  "sourceMap": true
                }
              },
              "defaultConfiguration": "production",
              "parallelism": true,
              "dependsOn": [
                "^build"
              ],
              "inputs": [
                "production",
                "^production"
              ]
            },
            "serve": {
              "executor": "@nx/angular:dev-server",
              "configurations": {
                "production": {
                  "buildTarget": "view:build:production"
                },
                "development": {
                  "buildTarget": "view:build:development",
                  "proxyConfig": "apps/view/proxy.conf.json"
                }
              },
              "defaultConfiguration": "development",
              "options": {},
              "parallelism": true
            },
            "extract-i18n": {
              "executor": "@nx/angular:extract-i18n",
              "options": {
                "buildTarget": "view:build"
              },
              "configurations": {},
              "parallelism": true
            },
            "test": {
              "executor": "@nx/jest:jest",
              "outputs": [
                "{workspaceRoot}/coverage/apps/view"
              ],
              "options": {
                "jestConfig": "apps/view/jest.config.ts",
                "passWithNoTests": true
              },
              "configurations": {},
              "parallelism": true,
              "inputs": [
                "default",
                "^production",
                "{workspaceRoot}/jest.preset.js"
              ]
            }
          },
          "implicitDependencies": [],
          "tags": []
        }
      },
      "api": {
        "name": "api",
        "type": "app",
        "data": {
          "root": "apps/api",
          "name": "api",
          "$schema": "../../node_modules/nx/schemas/project-schema.json",
          "sourceRoot": "apps/api/src",
          "projectType": "application",
          "tags": [],
          "targets": {
            "build": {
              "executor": "@nx/webpack:webpack",
              "outputs": [
                "{options.outputPath}"
              ],
              "options": {
                "target": "node",
                "compiler": "tsc",
                "outputPath": "dist/apps/api",
                "main": "apps/api/src/main.ts",
                "tsConfig": "apps/api/tsconfig.app.json",
                "webpackConfig": "apps/api/webpack.config.js"
              },
              "configurations": {
                "production": {
                  "optimization": true,
                  "extractLicenses": true,
                  "inspect": false
                }
              },
              "parallelism": true,
              "dependsOn": [
                "^build"
              ],
              "inputs": [
                "production",
                "^production"
              ]
            },
            "serve": {
              "executor": "@nx/js:node",
              "options": {
                "buildTarget": "api:build"
              },
              "configurations": {},
              "parallelism": true
            },
            "lint": {
              "executor": "@nx/eslint:lint",
              "outputs": [
                "{options.outputFile}"
              ],
              "options": {
                "lintFilePatterns": [
                  "apps/api/**/*.ts"
                ]
              },
              "configurations": {},
              "parallelism": true
            },
            "test": {
              "executor": "@nx/jest:jest",
              "outputs": [
                "{workspaceRoot}/coverage/apps/api"
              ],
              "options": {
                "jestConfig": "apps/api/jest.config.ts",
                "passWithNoTests": true
              },
              "configurations": {},
              "parallelism": true,
              "inputs": [
                "default",
                "^production",
                "{workspaceRoot}/jest.preset.js"
              ]
            }
          },
          "implicitDependencies": []
        }
      }
    },
    "dependencies": {
      "shared-models": [],
      "view": [
        {
          "source": "view",
          "target": "shared-models",
          "type": "static"
        }
      ],
      "api": []
    }
  }
}