# ERP Kepler dump (228MB, no versionar — restaurar localmente con pg_restore)
database/BACKUP.sql
*.sql.dump

# Backups/dumps sueltos de tiendas (data de prod, no versionar — p.ej. "backup tienda LPA...sql")
database/backup*.sql
# Dumps/exports sueltos en la raíz de database/ (p.ej. "R10 19-06-2026.sql", 42MB+).
# Los .sql legítimos viven en database/scripts/ (subdir, no afectado por esta regla).
database/*.sql
