+    void enqueueUpload(Location location) {
+        if (uploadUrl == null || location == null) return;
+        try {
+            SimpleDateFormat fmt = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss.SSS'Z'", Locale.US);
+            fmt.setTimeZone(TimeZone.getTimeZone("UTC"));
+            JSONObject p = new JSONObject();
+            p.put("client_uuid", UUID.randomUUID().toString());
+            if (uploadRouteId != null && uploadRouteId.length() > 0) p.put("route_id", uploadRouteId);
+            p.put("captured_at", fmt.format(new Date(location.getTime())));
+            p.put("lat", location.getLatitude());
+            p.put("lng", location.getLongitude());
+            if (location.hasAccuracy()) p.put("accuracy_m", location.getAccuracy());
+            if (location.hasSpeed()) p.put("speed_mps", location.getSpeed());
+            p.put("source", "background");
+            p.put("platform", "android");
+            synchronized (uploadQueue) {
+                uploadQueue.add(p);
+                while (uploadQueue.size() > UPLOAD_QUEUE_MAX) uploadQueue.remove(0);
+            }
+            scheduleFlush();
+        } catch (Exception e) {
+            Logger.error("enqueueUpload failed", e);
+        }
+    }
