{
  "name": "trade-marketing-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "api": "nx serve api",
    "view": "nx serve view",
    "generate:openapi": "ts-node scripts/generate-openapi.ts",
    "generate:client": "openapi-generator-cli generate -i swagger.json -g typescript-angular -o apps/view/src/app/core/api --additional-properties=stringEnums=true -c openapi-config.json",
    "api:gen": "npm run generate:openapi && npm run generate:client",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "migrate:latest": "knex migrate:latest --knexfile database/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile database/knexfile.js",
    "seed:run": "knex seed:run --knexfile database/knexfile.js",
    "doc:generate": "compodoc -p apps/view/tsconfig.json -d documentation --hideGenerator --disableGraph --disablePrivate --disableInternal --disableSourceCode",
    "doc:serve": "npx http-server documentation -p 8080 -o",
    "doc:build": "npm run doc:generate"
  },
  "dependencies": {
    "@angular/animations": "^18.2.0",
    "@angular/common": "^18.2.0",
    "@angular/compiler": "^18.2.0",
    "@angular/core": "^18.2.0",
    "@angular/forms": "^18.2.0",
    "@angular/platform-browser": "^18.2.0",
    "@angular/platform-browser-dynamic": "^18.2.0",
    "@angular/router": "^18.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/status-bar": "^8.0.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
