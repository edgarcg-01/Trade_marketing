# ─────────────────────────────────────────────────────────────────────────────
# Template de variables de entorno. Copiar a `.env` y rellenar con valores
# reales. NUNCA commitear el `.env` real al repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PREFIX=api
JWT_SECRET=cambiar_por_secret_largo_y_aleatorio_en_prod
JWT_EXPIRES_IN=8h
# Feature flag — true habilita stack multi-tenant (TenantContextInterceptor + auth-mt).
ENABLE_MULTITENANT=true
# Throttler — true desactiva rate limiting (regression suite database/run-all-tests.js lo setea).
THROTTLE_DISABLED=false

# ── DB Legacy (la actual, sigue operativa hasta el cutover) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=megadulces_logistica
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/megadulces_logistica
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/megadulces_logistica

# ── DB Nueva multi-tenant (postgres_platform — Sprint A.0-multitenant) ─────
# DATABASE_URL_NEW: usa role 'postgres' (superuser). Necesario para correr
# migraciones (CREATE TABLE, CREATE ROLE, etc.).
NEW_DB_HOST=192.168.0.245
NEW_DB_PORT=5432
NEW_DB_NAME=postgres_platform
NEW_DB_USER=postgres
NEW_DB_PASSWORD=cambiar_por_password_local
DATABASE_URL_NEW=postgresql://postgres:cambiar_por_password_local@192.168.0.245:5432/postgres_platform

# DATABASE_URL_NEW_RUNTIME: usa role 'app_runtime' (non-superuser, respeta RLS).
# La app NestJS DEBE usar este connection string en runtime. Si la app se
# conecta como 'postgres' BYPASSEARÍA RLS y expondría data cross-tenant.
DATABASE_URL_NEW_RUNTIME=postgresql://app_runtime:app_runtime@192.168.0.245:5432/postgres_platform
APP_RUNTIME_PASSWORD=app_runtime
# (en prod cambiar este password con: ALTER ROLE app_runtime WITH PASSWORD '...')

# Password del superoot del primer tenant. Usado en seeds-newdb/03_mega_dulces_superoot_user.js.
SUPEROOT_INITIAL_PASSWORD=

# ── Cutover legacy → nueva DB (database/scripts/cutover-*.js, migrate-legacy-to-newdb.js) ──
LEGACY_DATABASE_URL=
# TARGET_DB_URL: destino de importers/customers-from-excel.js y scripts/link-customers-to-stores.js.
TARGET_DB_URL=
# RAILWAY_DATABASE_URL: usada por diff-railway-vs-local.js para snapshot prod.
RAILWAY_DATABASE_URL=
# NEW_DATABASE_URL: distinto de DATABASE_URL_NEW — solo para railway-pgvector-minimal-migrate.js.
NEW_DATABASE_URL=
# Snapshot remoto del pgvector (Fase K-sync). Ver memoria project_fase_k_ai_match.
DATABASE_URL_REMOTE_SNAPSHOT=
# Railway pgvector (solo cuando se cutoveree Fase K a Railway).
RAILWAY_PGVECTOR_URL=

# ── Cloudinary (storage de imágenes) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ── Fase K — AI product match (captures) ──────────────────────────────────
# Voyage AI embeddings (ADR-011). Generar key en https://dash.voyageai.com
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3
# Anthropic Claude Haiku 4.5 — extracción estructurada del texto crudo
ANTHROPIC_API_KEY=
# Hard cap por request al endpoint /products/match-ai (protege costo + rate)
AI_PRODUCT_MATCH_MAX_ITEMS=50
# DB vector dedicada del RAG (Fase K v2). Postgres+pgvector SEPARADA (servicio
# propio en Railway). Si se deja vacía, el matcher cae a products.embedding de
# la DB legacy (KNEX_CONNECTION). Init: node database/scripts/init-vector-db.js
VECTOR_DATABASE_URL=
# Fuente del corpus para el sync (default = DATABASE_URL). Apuntar a la DB con
# el catálogo maestro public.products si difiere de la transaccional.
PRODUCT_SOURCE_URL=
# Máx productos re-embebidos por tick del cron de sync (acota costo Voyage).
VECTOR_SYNC_TICK_BATCH=200
# Dimensiones del embedding — debe matchear el modelo Voyage (voyage-3 = 1024).
VECTOR_EMBED_DIM=1024

# ── S3 storage (alternativa a Cloudinary — database/lib/s3-storage.js) ──────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ── Tests HTTP E2E (database/tests/*.js) ────────────────────────────────────
# Sin defaults — los tests usan localhost:3001 si no se setean.
API_URL=http://localhost:3001
API_BASE=http://localhost:3001
TENANT=mega_dulces
USER=
PASS=
# Para cutover-rollback-check.js (smoke prod tras cutover).
ROLLBACK_TEST_USER=
ROLLBACK_TEST_PASS=

# ── Seeds ───────────────────────────────────────────────────────────────────
# Permite re-correr 000_cleanup.js incluso en NODE_ENV=production. SOLO para reset deliberado.
FORCE_SEED_CLEANUP=false

# ── Socket.IO Redis adapter (multi-instance scaling) ───────────────────────
# Si está seteado, el API conecta a Redis y registra @socket.io/redis-adapter
# para que `server.to(room).emit(...)` llegue a todos los pods de la flota.
# Si vacío → adapter in-memory (single instance OK). Sin esto, escalar el API
# horizontalmente rompe los WS (un emit en pod A no llega a clientes de pod B).
# Formato: redis://[user:pass@]host:port[/db]   o  rediss:// para TLS.
# REDIS_URL=redis://localhost:6379

# ── Railway runtime (no setear localmente, lo inyecta Railway en prod) ─────
# PORT=10000
# API_PORT=3333

# Consolidación de ventas Kepler (cron polling). Opcional; sin esto el cron es inerte.
DATABASE_URL_KEPLER_CONSOLIDADO=postgresql://postgres:PASSWORD@localhost:5433/kepler_consolidado

# ── Proyecto Tienda (monitor de tickets en vivo) ──────────────────────────
# STORE_INGEST_KEY: clave compartida máquina-a-máquina. DEBE ser igual en el API
# (Railway) y en el poller on-prem. El endpoint /store/live/ingest la exige en el
# header x-store-ingest-key.
STORE_INGEST_KEY=cambiar_por_clave_ingest_larga_y_aleatoria
# STORE_INGEST_URL: SOLO en el poller on-prem. URL pública del ingest en prod.
#   STORE_INGEST_URL=https://<api-prod>/api/store/live/ingest
# STORE_LARGE_TICKET: umbral ($) para la alerta "ticket grande" (default 3000).
# STORE_LARGE_TICKET=3000
# Poller (on-prem): POLL_SECONDS=25  WINDOW_MINUTES=5
