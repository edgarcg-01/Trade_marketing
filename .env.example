# ─────────────────────────────────────────────────────────────────────────────
# Template de variables de entorno. Copiar a `.env` y rellenar con valores
# reales. NUNCA commitear el `.env` real al repo.
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PREFIX=api
JWT_SECRET=cambiar_por_secret_largo_y_aleatorio_en_prod

# ── DB Legacy (la actual, sigue operativa hasta el cutover) ────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=megadulces_logistica
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/megadulces_logistica
LOCAL_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/megadulces_logistica

# ── DB Nueva multi-tenant (postgres_platform — Sprint A.0-multitenant) ─────
# DATABASE_URL_NEW: usa role 'postgres' (superuser). Necesario para correr
# migraciones (CREATE TABLE, CREATE ROLE, etc.).
NEW_DB_HOST=192.168.0.245
NEW_DB_PORT=5432
NEW_DB_NAME=postgres_platform
NEW_DB_USER=postgres
NEW_DB_PASSWORD=cambiar_por_password_local
DATABASE_URL_NEW=postgresql://postgres:cambiar_por_password_local@192.168.0.245:5432/postgres_platform

# DATABASE_URL_NEW_RUNTIME: usa role 'app_runtime' (non-superuser, respeta RLS).
# La app NestJS DEBE usar este connection string en runtime. Si la app se
# conecta como 'postgres' BYPASSEARÍA RLS y expondría data cross-tenant.
DATABASE_URL_NEW_RUNTIME=postgresql://app_runtime:app_runtime@192.168.0.245:5432/postgres_platform
APP_RUNTIME_PASSWORD=app_runtime
# (en prod cambiar este password con: ALTER ROLE app_runtime WITH PASSWORD '...')

# ── Cloudinary (storage de imágenes) ────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_URL=

# ── Fase K — AI product match (captures) ──────────────────────────────────
# Voyage AI embeddings (ADR-011). Generar key en https://dash.voyageai.com
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3
# Anthropic Claude Haiku 4.5 — extracción estructurada del texto crudo
ANTHROPIC_API_KEY=
# Hard cap por request al endpoint /products/match-ai (protege costo + rate)
AI_PRODUCT_MATCH_MAX_ITEMS=50
# DB vector dedicada del RAG (Fase K v2). Postgres+pgvector SEPARADA (servicio
# propio en Railway). Si se deja vacía, el matcher cae a products.embedding de
# la DB legacy (KNEX_CONNECTION). Init: node database/scripts/init-vector-db.js
VECTOR_DATABASE_URL=
# Fuente del corpus para el sync (default = DATABASE_URL). Apuntar a la DB con
# el catálogo maestro public.products si difiere de la transaccional.
PRODUCT_SOURCE_URL=
# Máx productos re-embebidos por tick del cron de sync (acota costo Voyage).
VECTOR_SYNC_TICK_BATCH=200

# ── Socket.IO Redis adapter (multi-instance scaling) ───────────────────────
# Si está seteado, el API conecta a Redis y registra @socket.io/redis-adapter
# para que `server.to(room).emit(...)` llegue a todos los pods de la flota.
# Si vacío → adapter in-memory (single instance OK). Sin esto, escalar el API
# horizontalmente rompe los WS (un emit en pod A no llega a clientes de pod B).
# Formato: redis://[user:pass@]host:port[/db]   o  rediss:// para TLS.
# REDIS_URL=redis://localhost:6379

# ── Railway runtime (no setear localmente, lo inyecta Railway en prod) ─────
# PORT=10000
# API_PORT=3333
