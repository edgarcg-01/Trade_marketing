legacy-peer-deps=true
engine-strict=false
fund=false
audit=false

# Retries más agresivos para builds en Railway/Render donde la red entre
# el builder y el registry de npm puede ser inestable y tira "tarball data
# seems to be corrupted" en cientos de paquetes. Defaults: 3 retries, 1min max.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=180000
fetch-timeout=300000
