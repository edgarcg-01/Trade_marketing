# Config del servicio Kepler Live Poller (Opción A — node-windows).
# Copiá este archivo a `service.env` y completá los valores reales de PROD.
# `service.env` está gitignoreado (contiene la clave compartida) — NO lo commitees.

# URL del endpoint ingest en PROD (incluí /api).
STORE_INGEST_URL=https://TU-API-PROD/api/store/live/ingest

# Clave compartida — debe coincidir con STORE_INGEST_KEY del API en PROD.
STORE_INGEST_KEY=CAMBIAME_clave_fuerte

# Cadencia del poller. 60 = minuto a minuto.
POLL_SECONDS=60

# Ventana deslizante de lectura (min). Debe ser >= POLL_SECONDS para no perder tickets.
WINDOW_MINUTES=5
