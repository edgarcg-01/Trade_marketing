# Config local del sync automatico de Wincaja (NO commitear el archivo real).
# Copia este archivo a `sync.local.env` (gitignored) y pon la URL de PROD Railway.
# El wrapper sync-wincaja-actual.ps1 lo lee y setea DATABASE_URL_NEW.
DATABASE_URL_NEW=postgresql://USER:PASS@HOST.proxy.rlwy.net:PORT/railway

# Opcional: rutas de las carpetas Access si no son las default (Z:\Salidas\Bases\...)
# WINCAJA_ACTUALES=Z:\Salidas\Bases\Actuales
# WINCAJA_CONCENTRADAS=Z:\Salidas\Bases\Concentradas
