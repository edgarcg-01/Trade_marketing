<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Presencia de Marca · {{brand.name}}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
@page { size: A4; margin: 0; }
* { box-sizing: border-box; margin: 0; padding: 0; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
html, body { background: #fff; color: #0a0a0a; font-family: 'Inter', system-ui, sans-serif; font-size: 11px; line-height: 1.5; }
.page {
  width: 210mm; min-height: 297mm; padding: 18mm 16mm; position: relative;
  page-break-after: always; break-after: page; overflow: hidden;
}
.page:last-child { page-break-after: auto; break-after: auto; }
.serif { font-family: 'Fraunces', 'Times New Roman', serif; font-weight: 600; letter-spacing: -0.01em; }
.muted { color: #71717a; }
.faint { color: #a1a1aa; }
.strong { font-weight: 600; color: #18181b; }
.hr { border: 0; border-top: 1px solid #e4e4e7; margin: 12px 0; }
.uppercase { text-transform: uppercase; letter-spacing: 0.08em; font-size: 9px; font-weight: 600; color: #52525b; }

/* Header bar (repeating on inner pages) */
.header-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding-bottom: 10px; border-bottom: 1px solid #e4e4e7; margin-bottom: 22px;
}
.header-bar .brand-lockup { display: flex; align-items: center; gap: 10px; }
.header-bar .brand-lockup img { height: 24px; }
.header-bar .brand-lockup .tenant-name { font-weight: 700; font-size: 11px; letter-spacing: 0.04em; color: #18181b; }
.header-bar .doc-meta { text-align: right; font-size: 9px; color: #52525b; }
.header-bar .doc-meta .doc-title { font-weight: 600; color: #18181b; }

/* Footer */
.footer-bar {
  position: absolute; bottom: 10mm; left: 16mm; right: 16mm;
  display: flex; justify-content: space-between; align-items: center;
  font-size: 8.5px; color: #a1a1aa; border-top: 1px solid #f4f4f5; padding-top: 8px;
}

/* COVER */
.cover {
  display: flex; flex-direction: column; height: 261mm; padding: 0;
}
.cover-top {
  background: linear-gradient(135deg, #0a0a0a 0%, #1f1f23 70%, #2a2a30 100%);
  color: #fff; padding: 30mm 16mm 24mm 16mm; flex: 1;
  display: flex; flex-direction: column; justify-content: space-between;
}
.cover-top .badge { font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase; color: #d4d4d8; }
.cover-top h1 { font-family: 'Fraunces', serif; font-weight: 600; font-size: 48px; line-height: 1.05; margin: 12px 0 6px; letter-spacing: -0.02em; }
.cover-top h2 { font-family: 'Fraunces', serif; font-weight: 400; font-size: 22px; color: #e4e4e7; line-height: 1.2; }
.cover-top .period { margin-top: 28px; font-size: 12px; color: #d4d4d8; font-weight: 500; }
.cover-top .period .num { font-size: 16px; font-weight: 600; color: #fff; }
.cover-bottom { padding: 14mm 16mm; background: #fafafa; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12mm; }
.cover-bottom .cell { font-size: 9px; }
.cover-bottom .cell .label { text-transform: uppercase; letter-spacing: 0.12em; color: #71717a; font-weight: 600; font-size: 8.5px; }
.cover-bottom .cell .val { font-size: 12px; color: #18181b; font-weight: 600; margin-top: 4px; }
.cover-bottom .cell .val small { font-weight: 400; color: #52525b; }
.cover-tenant { display: flex; align-items: center; gap: 12px; }
.cover-tenant img { height: 32px; filter: brightness(0) invert(1); opacity: 0.95; }
.cover-tenant .name { font-weight: 700; letter-spacing: 0.06em; font-size: 12px; color: #fff; }

/* KPI cards */
.kpi-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 18px; }
.kpi {
  border: 1px solid #e4e4e7; border-radius: 10px; padding: 14px 16px;
  background: #fff; position: relative;
}
.kpi .label { font-size: 9px; color: #71717a; text-transform: uppercase; letter-spacing: 0.06em; font-weight: 600; }
.kpi .value { font-family: 'Fraunces', serif; font-size: 28px; font-weight: 600; color: #18181b; margin-top: 6px; line-height: 1; letter-spacing: -0.02em; }
.kpi .sublabel { font-size: 10px; color: #52525b; margin-top: 6px; }
.kpi .rag-pill {
  position: absolute; top: 12px; right: 14px;
  font-size: 8.5px; font-weight: 700; padding: 2px 7px; border-radius: 999px; letter-spacing: 0.04em; text-transform: uppercase;
}
.rag-green { background: #dcfce7; color: #14532d; }
.rag-amber { background: #fef3c7; color: #78350f; }
.rag-red { background: #fee2e2; color: #7f1d1d; }
.rag-neutral { background: #f4f4f5; color: #52525b; }
.kpi-bar { height: 3px; border-radius: 999px; margin-top: 10px; background: #f4f4f5; overflow: hidden; }
.kpi-bar > span { display: block; height: 100%; }
.kpi-bar > span.green { background: #16a34a; }
.kpi-bar > span.amber { background: #f59e0b; }
.kpi-bar > span.red { background: #dc2626; }

/* Section heading */
.section-title { font-family: 'Fraunces', serif; font-size: 20px; font-weight: 600; color: #18181b; margin-bottom: 4px; letter-spacing: -0.01em; }
.section-sub { font-size: 10.5px; color: #71717a; margin-bottom: 14px; }
.section-mark { display: inline-block; padding: 2px 8px; border-radius: 4px; background: #18181b; color: #fff; font-size: 8.5px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; margin-bottom: 10px; }

/* Tables */
table.data { width: 100%; border-collapse: collapse; font-size: 10px; }
table.data thead th {
  text-align: left; font-weight: 600; padding: 8px 10px; background: #18181b; color: #fafafa;
  font-size: 9px; letter-spacing: 0.06em; text-transform: uppercase;
}
table.data thead th.num, table.data tbody td.num { text-align: right; }
table.data tbody td { padding: 9px 10px; border-bottom: 1px solid #f4f4f5; color: #27272a; }
table.data tbody tr:nth-child(even) td { background: #fafafa; }
table.data tbody tr:last-child td { border-bottom: 0; }
.rag-cell { font-weight: 700; padding: 3px 8px; border-radius: 4px; display: inline-block; font-size: 9px; letter-spacing: 0.04em; }

/* Methodology cards */
.method-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.method-card { border: 1px solid #e4e4e7; border-radius: 10px; padding: 14px 16px; background: #fff; }
.method-card h4 { font-family: 'Fraunces', serif; font-size: 14px; margin-bottom: 6px; }
.method-card ul { margin-top: 6px; padding-left: 14px; }
.method-card ul li { font-size: 10px; color: #3f3f46; margin-bottom: 4px; line-height: 1.45; }
.method-card.warn { border-color: #fde68a; background: #fffbeb; }
.method-card.warn h4 { color: #78350f; }

/* Execution bar */
.exec-bar { display: flex; height: 14px; border-radius: 999px; overflow: hidden; background: #f4f4f5; margin: 10px 0 8px; }
.exec-bar > div { display: flex; align-items: center; justify-content: center; font-size: 8.5px; font-weight: 700; color: #fff; }
.exec-bar > .ok { background: #16a34a; }
.exec-bar > .mid { background: #f59e0b; }
.exec-bar > .bad { background: #dc2626; }
.exec-legend { display: flex; gap: 14px; font-size: 9.5px; color: #52525b; }
.exec-legend .dot { display: inline-block; width: 8px; height: 8px; border-radius: 2px; margin-right: 5px; vertical-align: middle; }

/* Chart container */
.chart-wrap { background: #fff; border: 1px solid #e4e4e7; border-radius: 10px; padding: 14px 16px; }
.chart-wrap .chart-canvas-wrap { height: 220px; position: relative; }

/* Banner */
.banner {
  background: #f4f4f5; border-left: 3px solid #18181b; padding: 10px 14px; border-radius: 4px;
  font-size: 10px; color: #3f3f46; margin: 10px 0 16px;
}
.banner strong { color: #18181b; }

/* Glossary */
.glossary { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; }
.glossary dt { font-weight: 700; color: #18181b; font-size: 10.5px; margin-top: 6px; }
.glossary dd { color: #52525b; font-size: 10px; margin-bottom: 6px; line-height: 1.45; }

/* No-data state */
.empty-state {
  border: 1px dashed #e4e4e7; padding: 40px; border-radius: 10px; text-align: center;
  color: #71717a; font-size: 11px;
}
.empty-state h3 { font-family: 'Fraunces', serif; font-size: 22px; color: #18181b; margin-bottom: 6px; }
</style>
</head>
<body>

{{!-- ===========================  COVER  =========================== --}}
<section class="page cover">
  <div class="cover-top">
    <div class="cover-tenant">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="name">{{tenant.name}}</span>
    </div>
    <div>
      <div class="badge">Reporte de Trade Marketing</div>
      <h1>Presencia<br>de Marca</h1>
      <h2>{{brand.name}}</h2>
      <div class="period">
        Periodo de análisis<br>
        <span class="num">{{period.label}}</span>
      </div>
    </div>
  </div>
  <div class="cover-bottom">
    <div class="cell">
      <div class="label">Preparado para</div>
      <div class="val">{{#if preparedFor}}{{preparedFor}}{{else}}{{brand.name}}{{/if}}</div>
    </div>
    <div class="cell">
      <div class="label">Preparado por</div>
      <div class="val">{{preparedBy.name}}<br><small>{{preparedBy.email}}</small></div>
    </div>
    <div class="cell">
      <div class="label">Generado</div>
      <div class="val">{{fmtDate generatedAt}}</div>
    </div>
  </div>
</section>

{{#if hasData}}

{{!-- ===========================  EXECUTIVE SUMMARY  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">01 · Resumen</div>
  <h2 class="section-title">Hallazgos clave del periodo</h2>
  <p class="section-sub">Indicadores de presencia de la marca <strong>{{brand.name}}</strong> en el conjunto de visitas auditadas durante <strong>{{period.label}}</strong>{{#if period.days}} ({{period.days}} días){{/if}}.</p>

  <div class="kpi-grid">
    {{#each kpis}}
    <div class="kpi">
      <div class="label">{{label}}</div>
      <div class="value">{{value}}</div>
      <div class="sublabel">{{sublabel}}</div>
      <span class="rag-pill {{ragClass rag}}">{{#if (eq rag "green")}}Saludable{{else if (eq rag "amber")}}Atención{{else if (eq rag "red")}}Crítico{{else}}—{{/if}}</span>
      <div class="kpi-bar"><span class="{{rag}}" style="width: {{value}};"></span></div>
    </div>
    {{/each}}
  </div>

  <div class="banner">
    <strong>Nota de interpretación.</strong>
    Los indicadores reflejan la <em>presencia</em> física observada en los exhibidores capturados — no representan Share of Shelf en su definición clásica (basada en facings o espacio lineal). Ver sección de <strong>Metodología</strong> en la página siguiente para el alcance exacto de cada métrica.
  </div>

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>Página 2</span>
  </div>
</section>

{{!-- ===========================  METHODOLOGY  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">02 · Metodología</div>
  <h2 class="section-title">Cómo se construyó este reporte</h2>
  <p class="section-sub">{{methodology.dataSource}} {{methodology.captureMethod}}</p>

  <div class="method-cols">
    <div class="method-card">
      <h4>Lo que se mide</h4>
      <ul>
        {{#each methodology.inScope}}<li>{{this}}</li>{{/each}}
      </ul>
    </div>
    <div class="method-card warn">
      <h4>Lo que NO se mide</h4>
      <ul>
        {{#each methodology.notInScope}}<li>{{this}}</li>{{/each}}
      </ul>
    </div>
  </div>

  <div class="banner" style="margin-top: 18px;">
    <strong>Limitaciones.</strong> {{methodology.limitations}}
  </div>

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>Página 3</span>
  </div>
</section>

{{!-- ===========================  COVERAGE & ZONES  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">03 · Cobertura</div>
  <h2 class="section-title">Cobertura y presencia por zona</h2>
  <p class="section-sub">Desglose del alcance de la marca por zona operativa.</p>

  <div class="kpi-grid" style="grid-template-columns: 1fr 1fr;">
    <div class="kpi">
      <div class="label">Visitas con la marca</div>
      <div class="value">{{fmtNum coverage.visitsWithBrand}} <span style="font-size: 14px; color:#a1a1aa;">/ {{fmtNum coverage.visits}}</span></div>
      <div class="sublabel">Cobertura del {{coverage.coverageRate}}%</div>
      <span class="rag-pill {{ragClass coverage.coverageRag}}">{{coverage.coverageRate}}%</span>
      <div class="kpi-bar"><span class="{{coverage.coverageRag}}" style="width: {{coverage.coverageRate}}%;"></span></div>
    </div>
    <div class="kpi">
      <div class="label">Exhibidores con la marca</div>
      <div class="value">{{fmtNum coverage.exhibitorsWithBrand}} <span style="font-size: 14px; color:#a1a1aa;">/ {{fmtNum coverage.exhibitors}}</span></div>
      <div class="sublabel">Frecuencia del {{coverage.presenceRate}}%</div>
      <span class="rag-pill {{ragClass coverage.presenceRag}}">{{coverage.presenceRate}}%</span>
      <div class="kpi-bar"><span class="{{coverage.presenceRag}}" style="width: {{coverage.presenceRate}}%;"></span></div>
    </div>
  </div>

  {{#if byZone.length}}
  <h3 class="serif" style="font-size: 14px; margin: 16px 0 8px;">Desempeño por zona</h3>
  <table class="data">
    <thead>
      <tr>
        <th style="width: 8%;">#</th>
        <th>Zona</th>
        <th class="num">Visitas</th>
        <th class="num">Exhibidores</th>
        <th class="num">Presencia</th>
        <th class="num">Cobertura</th>
        <th style="width: 14%;">Estado</th>
      </tr>
    </thead>
    <tbody>
      {{#each byZone}}
      <tr>
        <td class="muted">{{inc @index}}</td>
        <td class="strong">{{zone}}</td>
        <td class="num">{{fmtNum visits}}</td>
        <td class="num">{{fmtNum exhibitors}}</td>
        <td class="num">{{presence}}%</td>
        <td class="num">{{coverage}}%</td>
        <td><span class="rag-cell {{ragClass rag}}">{{#if (eq rag "green")}}OK{{else if (eq rag "amber")}}ATENCIÓN{{else}}CRÍTICO{{/if}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{else}}
  <div class="empty-state">Sin datos suficientes para desglose por zona en este periodo.</div>
  {{/if}}

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>Página 4</span>
  </div>
</section>

{{!-- ===========================  EXECUTION QUALITY  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">04 · Calidad de ejecución</div>
  <h2 class="section-title">Distribución de nivel de ejecución</h2>
  <p class="section-sub">Calidad observada en los <strong>{{fmtNum execution.total}}</strong> exhibidores donde aparece <strong>{{brand.name}}</strong>.</p>

  <div class="chart-wrap" style="margin-bottom: 14px;">
    <div class="exec-bar">
      {{#if (gt execution.optimoPct 0)}}<div class="ok" style="width: {{execution.optimoPct}}%;">{{execution.optimoPct}}%</div>{{/if}}
      {{#if (gt execution.regularPct 0)}}<div class="mid" style="width: {{execution.regularPct}}%;">{{execution.regularPct}}%</div>{{/if}}
      {{#if (gt execution.criticoPct 0)}}<div class="bad" style="width: {{execution.criticoPct}}%;">{{execution.criticoPct}}%</div>{{/if}}
    </div>
    <div class="exec-legend">
      <span><span class="dot" style="background:#16a34a"></span>Óptimo · {{fmtNum execution.optimo}}</span>
      <span><span class="dot" style="background:#f59e0b"></span>Regular · {{fmtNum execution.regular}}</span>
      <span><span class="dot" style="background:#dc2626"></span>Crítico · {{fmtNum execution.critico}}</span>
    </div>
  </div>

  <div class="kpi-grid" style="grid-template-columns: repeat(3, 1fr);">
    <div class="kpi">
      <div class="label">Óptimo</div>
      <div class="value" style="color:#16a34a">{{execution.optimoPct}}%</div>
      <div class="sublabel">{{fmtNum execution.optimo}} exhibidores nivel alto</div>
    </div>
    <div class="kpi">
      <div class="label">Regular</div>
      <div class="value" style="color:#f59e0b">{{execution.regularPct}}%</div>
      <div class="sublabel">{{fmtNum execution.regular}} con margen de mejora</div>
    </div>
    <div class="kpi">
      <div class="label">Crítico</div>
      <div class="value" style="color:#dc2626">{{execution.criticoPct}}%</div>
      <div class="sublabel">{{fmtNum execution.critico}} requieren acción</div>
    </div>
  </div>

  {{#if dailyTrend.length}}
  <h3 class="serif" style="font-size: 14px; margin: 18px 0 8px;">Tendencia diaria de presencia</h3>
  <div class="chart-wrap">
    <div class="chart-canvas-wrap"><canvas id="trendChart"></canvas></div>
  </div>
  {{/if}}

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>Página 5</span>
  </div>
</section>

{{!-- ===========================  TOP & BOTTOM SKUS  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">05 · Productos</div>
  <h2 class="section-title">SKUs más y menos presentes</h2>
  <p class="section-sub">Frecuencia de aparición de los productos de <strong>{{brand.name}}</strong> en los exhibidores capturados ({{fmtNum coverage.exhibitors}} exhibidores en el periodo).</p>

  {{#if topSkus.length}}
  <h3 class="serif" style="font-size: 14px; margin: 14px 0 6px;">Top productos</h3>
  <table class="data">
    <thead>
      <tr>
        <th style="width: 6%;">#</th>
        <th>Producto</th>
        <th class="num" style="width: 16%;">Apariciones</th>
        <th class="num" style="width: 14%;">% Exhibidores</th>
        <th style="width: 14%;">Estado</th>
      </tr>
    </thead>
    <tbody>
      {{#each topSkus}}
      <tr>
        <td class="muted">{{inc @index}}</td>
        <td class="strong">{{truncate name 70}}</td>
        <td class="num">{{fmtNum appearances}}</td>
        <td class="num">{{fmtPct coverageRate 1}}</td>
        <td><span class="rag-cell {{ragClass rag}}">{{#if (eq rag "green")}}FUERTE{{else if (eq rag "amber")}}MEDIO{{else}}DÉBIL{{/if}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  {{#if bottomSkus.length}}
  <h3 class="serif" style="font-size: 14px; margin: 22px 0 6px;">Productos con menor presencia · oportunidades</h3>
  <table class="data">
    <thead>
      <tr>
        <th style="width: 6%;">#</th>
        <th>Producto</th>
        <th class="num" style="width: 16%;">Apariciones</th>
        <th class="num" style="width: 14%;">% Exhibidores</th>
        <th style="width: 14%;">Estado</th>
      </tr>
    </thead>
    <tbody>
      {{#each bottomSkus}}
      <tr>
        <td class="muted">{{inc @index}}</td>
        <td class="strong">{{truncate name 70}}</td>
        <td class="num">{{fmtNum appearances}}</td>
        <td class="num">{{fmtPct coverageRate 1}}</td>
        <td><span class="rag-cell {{ragClass rag}}">{{#if (eq rag "green")}}FUERTE{{else if (eq rag "amber")}}MEDIO{{else}}DÉBIL{{/if}}</span></td>
      </tr>
      {{/each}}
    </tbody>
  </table>
  {{/if}}

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>Página 6</span>
  </div>
</section>

{{!-- ===========================  GLOSSARY  =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="section-mark">A · Glosario</div>
  <h2 class="section-title">Definiciones técnicas</h2>
  <p class="section-sub">Referencia rápida de los términos utilizados en este reporte.</p>

  <dl class="glossary">
    <div>
      <dt>Cobertura de tiendas</dt>
      <dd>Porcentaje de visitas en el periodo donde se observó al menos un producto de la marca en algún exhibidor de la tienda.</dd>
      <dt>Presencia en exhibidores</dt>
      <dd>Porcentaje de exhibidores capturados (vitrinas, paleteros, vitroleros, etc.) que contienen al menos un SKU de la marca.</dd>
      <dt>SKU con presencia</dt>
      <dd>Producto del catálogo de la marca que fue marcado por el personal de campo en al menos un exhibidor durante el periodo.</dd>
      <dt>Nivel de ejecución</dt>
      <dd>Calificación cualitativa otorgada al exhibidor por el personal de campo: Óptimo (alto), Regular (medio) o Crítico (bajo).</dd>
    </div>
    <div>
      <dt>Share of Shelf (SOS)</dt>
      <dd>Métrica estándar en CPG basada en facings o espacio lineal del anaquel. <strong>No incluida</strong> en este reporte por falta de captura de facings.</dd>
      <dt>Planograma</dt>
      <dd>Plano de referencia de cómo deben acomodarse los productos. <strong>No evaluado</strong> en este reporte por falta de planograma cliente.</dd>
      <dt>RAG</dt>
      <dd>Convención Red-Amber-Green (rojo-ámbar-verde) para señalizar estado: crítico, atención, saludable. Umbrales definidos por Mega Dulces y revisables por tenant.</dd>
      <dt>Periodo de análisis</dt>
      <dd>Ventana temporal sobre la que se calcularon los indicadores: {{period.label}}.</dd>
    </div>
  </dl>

  <div class="banner" style="margin-top: 22px;">
    <strong>Contacto.</strong> Para preguntas sobre la metodología, recálculos personalizados o solicitudes de captura adicional (facings, precios, planogramas), contacte al equipo de Trade Marketing de {{tenant.name}}: {{preparedBy.email}}.
  </div>

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing · Generado {{fmtDate generatedAt}}</span>
    <span>Reporte confidencial</span>
  </div>
</section>

{{else}}

{{!-- =========================== NO DATA STATE =========================== --}}
<section class="page">
  <div class="header-bar">
    <div class="brand-lockup">
      {{#if tenant.logoDataUri}}<img src="{{tenant.logoDataUri}}" alt="">{{/if}}
      <span class="tenant-name">{{tenant.name}}</span>
    </div>
    <div class="doc-meta">
      <div class="doc-title">Presencia · {{brand.name}}</div>
      <div>{{period.label}}</div>
    </div>
  </div>

  <div class="empty-state" style="margin-top: 60px;">
    <h3>Sin datos en el periodo seleccionado</h3>
    <p>No se encontraron capturas para <strong>{{brand.name}}</strong> entre <strong>{{period.label}}</strong>.</p>
    <p style="margin-top: 10px;">Verifique el rango de fechas y la cobertura del plan de visitas.</p>
  </div>

  <div class="footer-bar">
    <span>{{tenant.name}} · Trade Marketing</span>
    <span>—</span>
  </div>
</section>

{{/if}}

{{#if trendChartData.labels.length}}
<script>
(function () {
  try {
    var ctx = document.getElementById('trendChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: {{{json trendChartData.labels}}},
        datasets: [{
          label: 'Apariciones',
          data: {{{json trendChartData.data}}},
          backgroundColor: '#18181b',
          borderRadius: 3,
          maxBarThickness: 22,
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        animation: false,
        plugins: {
          legend: { display: false },
          tooltip: { enabled: false },
        },
        scales: {
          x: { grid: { display: false }, ticks: { font: { family: 'Inter', size: 9 }, color: '#71717a' } },
          y: { beginAtZero: true, grid: { color: '#f4f4f5' }, ticks: { font: { family: 'Inter', size: 9 }, color: '#71717a' } }
        }
      }
    });
  } catch (e) {
    console.error('chart render failed', e);
  }
})();
</script>
{{/if}}

</body>
</html>
