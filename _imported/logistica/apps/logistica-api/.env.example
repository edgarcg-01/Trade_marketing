# Database Configuration (Local Development)
# Asegúrate de tener PostgreSQL corriendo localmente en el puerto 5432
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trade_marketing
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Secret
JWT_SECRET=super_secret_dev_key_change_in_prod

# Environment
NODE_ENV=development

# API Prefix (optional, defaults to 'api')
# API_PREFIX=api
